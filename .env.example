# Velvet Reverie - Environment Configuration Template
# Copy this file to .env and customize your settings

# ==================== Flask Application ====================
# Host address for Flask server (0.0.0.0 allows external connections)
FLASK_HOST=0.0.0.0
# Port for Flask web interface
FLASK_PORT=4879
# Enable debug mode (True/False) - disable in production!
FLASK_DEBUG=False
# Secret key for session encryption - CHANGE THIS TO A RANDOM STRING!
FLASK_SECRET_KEY=velvet-reverie-secret-key
# Session lifetime in days for "remember me" feature
SESSION_LIFETIME_DAYS=30

# ==================== Authentication ====================
# Password hash for login (SHA256)
# To generate: python -c "import hashlib; print(hashlib.sha256('YOUR_PASSWORD'.encode()).hexdigest())"
# Default is "password" - CHANGE THIS!
PASSWORD_HASH=f9031e664507bef426d72ed433ed4a07d47aefa362285b757186c6f8a7a1bf76

# ==================== ComfyUI Configuration ====================
# ComfyUI server address
COMFYUI_HOST=127.0.0.1
COMFYUI_PORT=8188
# ComfyUI API token (if password protection is enabled)
# Leave empty if no authentication required
COMFYUI_TOKEN=

# ==================== Ollama Configuration ====================
# Ollama server address for AI chat/story generation
OLLAMA_HOST=127.0.0.1
OLLAMA_PORT=11434

# ==================== Gradio TTS Configuration ====================
# Gradio ChatterBox TTS server address
GRADIO_HOST=127.0.0.1
GRADIO_PORT=7860
GRADIO_OUTPUT_DIR=../Ultimate-TTS-Studio.git/app/outputs

# ==================== Paths & Directories ====================
# Output directory for generated media
OUTPUT_DIR=outputs
# Directory containing ComfyUI workflow JSON files
WORKFLOWS_DIR=workflows

# ComfyUI file paths (adjust if ComfyUI is installed elsewhere)
COMFYUI_INPUT_DIR=../comfy.git/app/input
COMFYUI_OUTPUT_DIR=../comfy.git/app/output

# Documentation directory for AI instructions
DOCS_DIR=docs

# Specific workflow file paths (relative to WORKFLOWS_DIR or absolute)
WORKFLOW_QWEN=Qwen_Full (API).json
WORKFLOW_VIDEO=Wan2.2 I2V (API).json
WORKFLOW_VIDEO_NSFW=Wan2.2 I2V NSFW (API).json
WORKFLOW_TTS=TTSVibe (API).json

# ==================== Queue & Processing ====================
# Maximum number of completed jobs to keep in history
MAX_COMPLETED_HISTORY=50
# Note: QUEUE_START_PAUSED and AUTO_UNLOAD_MODELS are controlled via the web UI
